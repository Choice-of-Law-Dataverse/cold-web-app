{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": "^22.18"
  },
  "scripts": {
    "build": "nuxt build --log-level silent",
    "check": "pnpm run format && pnpm run lint:fix && pnpm run typecheck && pnpm run test:run",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "start": "nuxt start",
    "lint": "eslint . --quiet",
    "lint:fix": "eslint . --fix --quiet",
    "format": "prettier --log-level silent --write .",
    "format:check": "prettier --log-level silent --check .",
    "knip": "knip",
    "typecheck": "vue-tsc --noEmit --pretty false -p tsconfig.json",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run --reporter=dot",
    "test:coverage": "vitest run --reporter=dot --coverage",
    "generate:api": "cd ../backend && LOGFIRE_SEND_TO_LOGFIRE=false uv run python scripts/export_openapi.py && cd ../frontend && pnpm dlx openapi-typescript app/types/openapi.json -o app/types/api-schema.d.ts"
  },
  "dependencies": {
    "@auth0/auth0-nuxt": "^1.0.1",
    "@aws-sdk/client-s3": "^3.1024.0",
    "@aws-sdk/s3-request-presigner": "^3.1024.0",
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/material-symbols": "^1.2.65",
    "@nuxt/content": "^3.12.0",
    "@nuxt/fonts": "^0.13.0",
    "@nuxt/icon": "^2.2.1",
    "@nuxt/scripts": "^0.13.2",
    "@nuxt/ui": "^4.6.1",
    "@nuxtjs/leaflet": "^1.3.2",
    "@nuxtjs/robots": "^5.7.1",
    "@nuxtjs/sitemap": "^7.6.0",
    "@opentelemetry/api": "^1.9.1",
    "@pydantic/logfire-node": "^0.12.0",
    "@tanstack/vue-query": "^5.96.2",
    "@unhead/vue": "^2.1.12",
    "better-sqlite3": "^12.8.0",
    "date-fns": "^4.1.0",
    "leaflet": "^1.9.4",
    "mitt": "^3.0.1",
    "nuxt": "^4.4.2",
    "openapi-fetch": "^0.17.0",
    "v-calendar": "^3.1.2",
    "vue": "^3.5.32",
    "zod": "^3.25.76"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "better-sqlite3",
      "esbuild",
      "unrs-resolver"
    ],
    "overrides": {
      "serialize-javascript@<=7.0.2": ">=7.0.3"
    }
  },
  "devDependencies": {
    "@iconify-json/bi": "^1.2.7",
    "@iconify-json/lucide": "^1.2.101",
    "@iconify-json/mdi": "^1.2.3",
    "@nuxt/eslint": "^1.15.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/vue-query-devtools": "^6.1.13",
    "@types/node": "^22.19.17",
    "@vitest/ui": "^4.1.2",
    "@vue/test-utils": "^2.4.6",
    "baseline-browser-mapping": "^2.10.14",
    "eslint": "^9.39.4",
    "eslint-plugin-perfectionist": "^5.8.0",
    "happy-dom": "^20.8.9",
    "knip": "^5.88.1",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.6"
  }
}
