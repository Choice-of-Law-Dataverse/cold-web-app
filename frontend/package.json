{
  "name": "nuxt-app",
  "author": {
    "name": "Marcos Messer",
    "email": "git@marcosmesser.com",
    "url": "https://marcosmesser.com"
  },
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": "^22.18"
  },
  "scripts": {
    "build": "nuxt build --log-level silent",
    "check": "pnpm run format && pnpm run lint:fix && pnpm run typecheck && pnpm run test:run",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "start": "nuxt start",
    "lint": "eslint . --quiet",
    "lint:fix": "eslint . --fix --quiet",
    "format": "prettier --log-level silent --write .",
    "format:check": "prettier --log-level silent --check .",
    "knip": "knip",
    "typecheck": "vue-tsc --noEmit --pretty false -p tsconfig.json",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run --reporter=dot",
    "test:coverage": "vitest run --reporter=dot --coverage",
    "generate:api": "cd ../backend && LOGFIRE_SEND_TO_LOGFIRE=false uv run python scripts/export_openapi.py && cd ../frontend && pnpm dlx openapi-typescript app/types/openapi.json -o app/types/api-schema.d.ts"
  },
  "dependencies": {
    "@auth0/auth0-nuxt": "^1.1.0",
    "@aws-sdk/client-s3": "^3.1090.0",
    "@aws-sdk/s3-request-presigner": "^3.1090.0",
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/material-symbols": "^1.2.85",
    "@nuxt/content": "^3.15.0",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/icon": "^2.3.1",
    "@nuxt/scripts": "^1.3.1",
    "@nuxt/ui": "^4.10.0",
    "@nuxtjs/leaflet": "^1.3.2",
    "@nuxtjs/robots": "^6.1.2",
    "@nuxtjs/sitemap": "^8.2.2",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.220.0",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/context-async-hooks": "^2.9.0",
    "@opentelemetry/core": "^2.9.0",
    "@opentelemetry/exporter-logs-otlp-proto": "^0.220.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.220.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.220.0",
    "@opentelemetry/instrumentation": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-logs": "^0.220.0",
    "@opentelemetry/sdk-metrics": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@opentelemetry/sdk-trace-base": "^2.9.0",
    "@opentelemetry/semantic-conventions": "^1.43.0",
    "@pydantic/logfire-node": "^0.18.4",
    "@tanstack/vue-query": "^5.101.2",
    "better-sqlite3": "^12.11.1",
    "date-fns": "^4.4.0",
    "leaflet": "^1.9.4",
    "mitt": "^3.0.1",
    "nuxt": "^4.5.0",
    "openapi-fetch": "^0.17.0",
    "v-calendar": "^3.1.2",
    "vue": "^3.5.40",
    "zod": "^3.25.76"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "better-sqlite3",
      "esbuild",
      "unrs-resolver"
    ],
    "overrides": {
      "serialize-javascript@<=7.0.2": ">=7.0.3"
    }
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.118",
    "@iconify-json/simple-icons": "^1.2.90",
    "@nuxt/eslint": "^1.16.0",
    "@nuxt/eslint-config": "^1.16.0",
    "@tailwindcss/vite": "^4.3.3",
    "@tanstack/vue-query-devtools": "^6.1.36",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^22.20.1",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.7.0",
    "eslint-plugin-perfectionist": "^5.10.0",
    "h3": "^1.15.11",
    "happy-dom": "^20.11.0",
    "knip": "^6.27.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7"
  }
}
